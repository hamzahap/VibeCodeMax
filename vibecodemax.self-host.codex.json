{
  "workspace": ".",
  "task": {
    "title": "Self-host VibeCodeMax with Codex",
    "objective": "Audit and improve the VibeCodeMax repository until it is a strong self-hosting release for autonomous coding-agent execution. Treat the current outer VibeCodeMax run as the proof self-host run, and do not start nested `npm run self-host:*` or `node dist/src/cli.js run ...` loops from inside the agent. If the repo already satisfies the completion criteria, avoid unnecessary churn and leave the workspace passing verification.",
    "scopeFile": "docs/current-scope.md",
    "completionCriteria": [
      "Everything in docs/current-scope.md is satisfied.",
      "npm test passes.",
      "The final state is verifiable through this completed self-host run."
    ],
    "contextFiles": [
      "README.md",
      "package.json",
      "src/agents.ts",
      "src/orchestrator.ts",
      "src/auditor.ts",
      "src/config.ts",
      "src/runs.ts",
      "src/cli.ts"
    ]
  },
  "budgets": {
    "mode": "until_complete",
    "maxRuntimeMinutes": 25
  },
  "agents": {
    "primary": {
      "type": "codex_exec",
      "model": "gpt-5.4",
      "dangerouslyBypassApprovalsAndSandbox": true,
      "estimatedTokensPerRun": 12000
    },
    "auditor": {
      "type": "codex_exec",
      "model": "gpt-5.4-mini",
      "dangerouslyBypassApprovalsAndSandbox": true,
      "estimatedTokensPerRun": 4000,
      "jsonSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "decision": {
            "type": "string",
            "enum": ["complete", "continue"]
          },
          "summary": {
            "type": "string"
          },
          "nextPrompt": {
            "type": "string"
          }
        },
        "required": ["decision", "summary", "nextPrompt"]
      }
    }
  },
  "run": {
    "primaryAgent": "primary",
    "auditorAgent": "auditor",
    "requiredFiles": [
      "docs/current-scope.md",
      "README.md",
      "src/agents.ts",
      "vibecodemax.self-host.codex.json",
      "vibecodemax.self-host.claude.json"
    ],
    "verification": [
      {
        "name": "npm-test",
        "command": "cmd /c npm test"
      }
    ],
    "maxNoChangeAttempts": 2
  }
}
